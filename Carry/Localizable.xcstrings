    "Parked in the sun, your steering wheel becomes untouchable — costs almost nothing to prevent" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In der Sonne geparkt wird dein Lenkrad unberührbar — kostet fast nichts, um es zu verhindern"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parked in the sun, your steering wheel becomes untouchable — costs almost nothing to prevent"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aparcado al sol, tu volante se vuelve intocable — cuesta casi nada prevenirlo"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Garé au soleil, votre volant devient intouchable — coûte presque rien à prévenir"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "炎天下に駐車すると、ハンドルが触れないほど熱くなる — 防ぐのにほぼコストはかからない"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "햇볕에 주차하면 핸들을 잡을 수 없게 됩니다 — 예방하는 데 거의 비용이 들지 않아요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estacionado no sol, o volante fica intocável — custa quase nada prevenir"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暴晒后方向盘会很烫，加个遮阳挡成本低但体感提升明显"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在陽光下停車，方向盤會燙得無法觸碰——預防幾乎不花錢"
          }
        }
      }
    },
    "Passenger-seat naps are so much better with a real blanket — one that lives in the boot ready to go" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nickerchen auf dem Beifahrersitz sind mit einer echten Decke so viel besser — eine, die im Kofferraum bereitliegt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passenger-seat naps are so much better with a real blanket — one that lives in the boot ready to go"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las siestas en el asiento del copiloto son mucho mejores con una manta de verdad — una que viva en el maletero lista para usar"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les siestes en siège passager sont tellement meilleures avec une vraie couverture — une qui vit dans le coffre, prête à l'emploi"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "助手席でのうたた寝は本物のブランケットがあればずっと快適 — トランクに入れっぱなしにしておけばいつでも使える"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "조수석 낮잠은 진짜 담요가 있으면 훨씬 좋습니다 — 트렁크에 항상 준비해두는 담요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cochilos no banco do passageiro são muito melhores com um cobertor de verdade — um que fica no porta-malas pronto para usar"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "副驾小睡时有一条顺手的小毯子，舒适度会明显提升"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "副駕小睡時有一條順手的小毯子，舒適度會明顯提升"
          }
        }
      }
    },
