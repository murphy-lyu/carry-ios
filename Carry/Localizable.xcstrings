    "Fast airport transfers and long terminal walks can shred your heels — applying one early can save your first day" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schnelle Umsteigetransfers und lange Terminalwege können die Fersen aufscheuern — frühzeitig aufgetragen kann das den ersten Tag retten"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los traslados rápidos en el aeropuerto y los largos paseos por la terminal pueden destrozarte los talones — aplicarlos pronto puede salvarte el primer día"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les transferts rapides et les longues marches en aéroport peuvent meurtrir vos talons — en appliquer un tôt peut sauver votre premier jour"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "急いだ乗り換えや長いターミナルの歩行でかかとが擦り切れることがある——早めに貼れば初日を救える"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "빠른 환승과 긴 터미널 이동은 발뒤꿈치를 망가뜨릴 수 있어요 — 미리 붙이면 첫날을 구할 수 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transferências rápidas e longas caminhadas no terminal podem rasgar seus calcanhares — aplicar um cedo pode salvar seu primeiro dia"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速转机和长途步行会磨破脚跟——提早贴上，可以救你的第一天"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速轉機和長途步行會磨破腳跟——提早貼上，可以救你的第一天"
          }
        }
      }
    },
