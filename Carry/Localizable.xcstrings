    "settings.data.recovery.explanation" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn deine Reisen nach einem App-Update oder einer Gerätewiederherstellung verschwunden sind, kannst du sie aus dem letzten automatischen Speicher unten wiederherstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your trip data is backed up locally. Restore it here if anything is accidentally lost."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tus viajes desaparecieron tras una actualización de la app o restauración del dispositivo, puedes recuperarlos desde el autoguardado más reciente a continuación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vos voyages ont disparu après une mise à jour de l'app ou une restauration de l'appareil, vous pouvez les récupérer depuis la dernière sauvegarde automatique ci-dessous."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリのアップデートやデバイスのリストア後に旅行データが消えた場合、下の最新の自動保存から復元できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앱 업데이트 또는 기기 복원 후 여행이 사라진 경우, 아래의 가장 최근 자동 저장에서 복구할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se suas viagens desapareceram após uma atualização do app ou restauração do dispositivo, você pode recuperá-las do salvamento automático mais recente abaixo."
          }
        },
        "zh-Hans" : {
