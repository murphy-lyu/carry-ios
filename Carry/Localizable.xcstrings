        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "位置情報はあるが、旅行期間外に撮影された写真。旅行の日付を変えると取り込める。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치 정보는 있지만 여행 날짜 밖에서 찍힌 사진이에요. 여행 날짜를 바꾸면 포함할 수 있어요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas fotos têm localização, mas foram tiradas fora das datas da viagem. Ajuste as datas para incluí-las."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这些照片有位置，但拍摄日不在出发~返程之间。改行程日期可把它们纳入。"
