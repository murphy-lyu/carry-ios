    "In heavy rain, putting your phone, cards, and tickets inside removes a lot of avoidable stress" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei starkem Regen nimmt das Verstauen von Handy, Karten und Tickets darin viel vermeidbaren Stress"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En lluvia intensa, meter el teléfono, las tarjetas y los billetes dentro elimina mucho estrés evitable"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Par forte pluie, y glisser son téléphone, ses cartes et ses billets supprime beaucoup de stress évitable"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大雨のとき、スマートフォン、カード、チケットを中に入れると、避けられたはずのストレスがかなり減る"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "폭우 속에서 핸드폰, 카드, 티켓을 안에 넣으면 피할 수 있었던 스트레스를 많이 줄일 수 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Na chuva forte, colocar celular, cartões e ingressos dentro elimina muito estresse evitável"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大雨时，把手机、银行卡和票据放进去，能减少很多本可避免的焦虑"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大雨時，把手機、銀行卡和票據放進去，能減少很多本可避免的焦慮"
          }
        }
      }
    },
