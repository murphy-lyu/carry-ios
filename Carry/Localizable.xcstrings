    "This will permanently delete your packing list and all progress." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden deine Packliste und der gesamte Fortschritt dauerhaft gelöscht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete your packing list and all progress."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará permanentemente tu lista de equipaje y todo el progreso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action supprimera définitivement votre liste de bagages et toute votre progression."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パッキングリストとすべての進捗が完全に削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "준비물 목록과 모든 진행 상황이 영구적으로 삭제돼요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso excluirá permanentemente sua lista de bagagem e todo o progresso."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清单和打包进度将被永久删除，无法恢复。"
          }
        },
