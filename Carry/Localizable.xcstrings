    "settings.notif.footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Erinnerungen gelten für alle Reisen. Einen einzelnen Flug oder Aufenthalt auf dessen Detailseite stummschalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These reminders apply to every trip. To mute one flight or stay, turn it off on its detail page."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estos recordatorios se aplican a todos los viajes. Silencia un vuelo o alojamiento desde su página de detalle."
