    "City days can hit 20k+ steps — insoles can save your feet by day two" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Städtetage können 20.000+ Schritte erreichen — Einlegesohlen können deine Füße bis zum zweiten Tag retten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "City days can hit 20k+ steps — insoles can save your feet by day two"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los días de ciudad pueden superar los 20.000 pasos — las plantillas pueden salvar tus pies ya en el segundo día"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les journées en ville peuvent atteindre 20 000+ pas — des semelles peuvent sauver vos pieds dès le deuxième jour"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "都市観光では2万歩を超えることも — インソールがあれば2日目も足を守れる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도시 여행에서는 2만 보 이상 걷기도 합니다 — 깔창이 이틀째 발을 구해줄 수 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dias na cidade podem chegar a 20 mil+ passos — palmilhas podem salvar seus pés até o segundo dia"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "城市暴走很费脚，鞋垫能明显减轻第二天疲劳"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "城市遊一天可能走兩萬步以上——鞋墊能在第二天前救你的腳"
          }
        }
      }
    },
    "Clip it on and take your phone into the water — suddenly every boat trip, beach swim, or waterfall is fully documented" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einfach befestigen und das Handy ins Wasser mitnehmen — plötzlich kann jede Bootsfahrt, jeder Strandschwimm oder Wasserfall vollständig dokumentiert werden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clip it on and take your phone into the water — suddenly every boat trip, beach swim, or waterfall is fully documented"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ponlo y lleva tu teléfono al agua — de repente cada paseo en bote, nado en la playa o cascada queda completamente documentado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attachez-le et emmenez votre téléphone dans l'eau — soudain, chaque sortie en bateau, baignade ou cascade est entièrement documentée"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "つけてスマホを水に持ち込もう。ボートトリップ、海水浴、滝など、すべての瞬間が記録できるようになります"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "클립으로 고정하고 폰을 물에 가져가세요. 보트 여행, 해수욕, 폭포 등 모든 순간이 완전히 기록됩니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coloque e leve seu celular para a água — de repente, cada passeio de barco, mergulho na praia ou cachoeira fica completamente documentado"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "套上它，把手机带进水里——从此每一次船游、泳池、瀑布，都有了完整的记录"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "套上它，把手機帶進水裡——從此每一次船遊、游泳、瀑布，都有了完整的記錄"
          }
        }
      }
    },
