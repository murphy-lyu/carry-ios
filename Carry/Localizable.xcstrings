    "De-creases a shirt in two minutes — more effective than an iron on most fabrics, and takes up almost no space" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Glättet ein Hemd in zwei Minuten — effektiver als ein Bügeleisen bei den meisten Stoffen und nimmt kaum Platz weg"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De-creases a shirt in two minutes — more effective than an iron on most fabrics, and takes up almost no space"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desagruga una camisa en dos minutos — más eficaz que una plancha en la mayoría de las telas y ocupa casi nada"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Défroise une chemise en deux minutes — plus efficace qu'un fer à repasser sur la plupart des tissus, et prend presque pas de place"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シャツのシワを2分で取る — ほとんどの素材でアイロンより効果的、しかもほとんど場所を取らない"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "셔츠 주름을 2분 만에 펴줍니다 — 대부분의 소재에서 다리미보다 효과적이고, 공간도 거의 차지하지 않아요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tira amassados de uma camisa em dois minutos — mais eficaz que um ferro na maioria dos tecidos, e ocupa quase nenhum espaço"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
