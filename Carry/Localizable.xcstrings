    "phototrip.excluded.outofrange.hint" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Fotos haben einen Ort, wurden aber außerhalb des Reisezeitraums aufgenommen. Passe die Reisedaten an, um sie einzuschließen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These photos have a location, but were taken outside your trip's start–return dates. Adjust the trip dates to include them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas fotos tienen ubicación, pero se tomaron fuera de las fechas del viaje. Ajusta las fechas para incluirlas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
