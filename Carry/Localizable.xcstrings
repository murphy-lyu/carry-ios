    "Packs to the size of a biscuit, costs almost nothing — for when the umbrella is in the bag and the rain starts now" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Packt sich auf Keksgröße zusammen, kostet fast nichts — für wenn der Regenschirm in der Tasche ist und der Regen jetzt anfängt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Packs to the size of a biscuit, costs almost nothing — for when the umbrella is in the bag and the rain starts now"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se dobla hasta el tamaño de una galleta, cuesta casi nada — para cuando el paraguas está en la bolsa y la lluvia empieza ahora"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se plie à la taille d'un biscuit, coûte presque rien — pour quand le parapluie est dans le sac et que la pluie commence maintenant"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クッキーサイズに畳めて、ほぼタダ — 傘をバッグに入れたまま雨が降り出したときのために"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비스킷 크기로 접히고, 거의 공짜 — 우산이 가방 안에 있고 지금 비가 내리기 시작할 때를 위해"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cabe no bolso como um biscoito, custa quase nada — para quando o guarda-chuva está na bolsa e a chuva começa agora"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "体积小、价格低，临时下雨时很实用"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "體積小、價格低，臨時下雨時很實用"
          }
        }
      }
    },
