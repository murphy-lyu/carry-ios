    "Worn on the pressure point above the wrist — more stylish than patches and surprisingly effective for mild seasickness" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Am Druckpunkt über dem Handgelenk getragen — stilvoller als Pflaster und überraschend wirksam gegen leichte Seekrankheit"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Worn on the pressure point above the wrist — more stylish than patches and surprisingly effective for mild seasickness"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Llevado en el punto de presión sobre la muñeca — más elegante que los parches y sorprendentemente efectivo para el mareo leve"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Porté sur le point de pression au-dessus du poignet — plus élégant que les patchs et étonnamment efficace contre le mal de mer léger"
