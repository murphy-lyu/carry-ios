    "settings.data.erase.confirm.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle Reisen, Packlisten und Anhänge dauerhaft von diesem Gerät entfernt. Das lässt sich nicht rückgängig machen – exportiere zuerst ein Backup, wenn du eine Kopie behalten möchtest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This permanently removes all trips, packing lists, and attachments from this device. It can't be undone — export a backup first if you'd like to keep a copy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto elimina permanentemente todos los viajes, listas de equipaje y archivos adjuntos de este dispositivo. No se puede deshacer: exporta una copia de seguridad primero si quieres conservar una copia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprime définitivement tous les voyages, listes de bagages et pièces jointes de cet appareil. Cette action est irréversible — exportez d'abord une sauvegarde si vous souhaitez en garder une copie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この端末のすべての旅行・荷物リスト・添付ファイルが完全に削除され、元に戻せません。コピーを残したい場合は、先にバックアップを書き出してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 기기의 모든 여행, 짐 목록, 첨부 파일이 영구적으로 삭제되며 되돌릴 수 없습니다. 사본을 남기려면 먼저 백업을 내보내세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso remove permanentemente todas as viagens, listas de bagagem e anexos deste dispositivo. Não é possível desfazer — exporte um backup primeiro se quiser manter uma cópia."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将永久删除本机的全部行程、打包清单与附件，且无法恢复。想留副本，可先用「导出」备份。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將永久刪除本機的全部行程、打包清單與附件，且無法復原。想留副本，可先用「匯出」備份。"
          }
        }
      }
    },
