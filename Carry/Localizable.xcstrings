    "Tiny but surprisingly versatile: clip wet socks to dry, seal snack bags, or secure loose small items" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klein, aber erstaunlich vielseitig: nasse Socken trocknen, Snack-Beutel verschließen, kleine Teile sichern"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pequeños pero sorprendentemente versátiles: cuelga calcetines húmedos, sella bolsas de snacks o sujeta pequeños objetos"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Petits mais étonnamment polyvalents : faire sécher des chaussettes mouillées, fermer des sachets de snacks ou fixer de petits objets"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小さいのに驚くほど多用途：濡れた靴下を干す、お菓子袋を閉じる、小物を固定する"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "작지만 놀랍도록 활용도가 높아요: 젖은 양말 말리기, 과자 봉지 봉하기, 작은 물건 고정하기"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pequenos mas surpreendentemente versáteis: pendure meias molhadas para secar, feche sacos de lanche ou prenda pequenos objetos soltos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小但出奇好用：晾湿袜子、封零食袋、固定小东西"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小但出奇好用：晾濕襪子、封零食袋、固定小東西"
          }
        }
      }
    },
