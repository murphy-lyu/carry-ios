    "Hotel rooms never have enough — three extra hangers solve the whole wardrobe problem" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hotelzimmer haben nie genug — drei zusätzliche Kleiderbügel lösen das gesamte Kleidungsproblem"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hotel rooms never have enough — three extra hangers solve the whole wardrobe problem"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las habitaciones de hotel nunca tienen suficientes — tres perchas extra resuelven todo el problema del armario"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les chambres d'hôtel n'en ont jamais assez — trois cintres supplémentaires règlent tout le problème de garde-robe"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホテルの部屋には絶対に足りない — ハンガーを3本余分に持ってくれば収納問題がすべて解決する"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "호텔 방에는 항상 부족합니다 — 여분 옷걸이 세 개가 옷장 문제를 전부 해결해줘요"
