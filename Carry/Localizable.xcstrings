    "Hot water on demand in your hotel room — instant noodles at midnight, morning tea without waiting for room service" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heißes Wasser auf Abruf im Hotelzimmer — Instant-Nudeln um Mitternacht, Morgentee ohne auf den Zimmerservice zu warten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hot water on demand in your hotel room — instant noodles at midnight, morning tea without waiting for room service"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agua caliente disponible en tu habitación de hotel — fideos instantáneos a medianoche, té matutino sin esperar al servicio de habitaciones"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De l'eau chaude à la demande dans votre chambre d'hôtel — des nouilles instantanées à minuit, du thé du matin sans attendre le service en chambre"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホテルの部屋でいつでもお湯が使える — 真夜中のインスタントラーメン、ルームサービスを待たずに朝のお茶"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "호텔 방에서 원할 때 바로 뜨거운 물을 — 자정의 라면, 룸서비스 기다릴 필요 없는 아침 차"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Água quente na hora no seu quarto de hotel — macarrão instantâneo à meia-noite, chá de manhã sem esperar o serviço de quarto"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "酒店房间里随时有热水，夜宵和早茶都会方便很多"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "酒店房間裡隨時有熱水，宵夜和早茶都會方便很多"
          }
        }
      }
    },
