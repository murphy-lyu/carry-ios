        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les repas en avion ne coïncident jamais avec ta vraie faim — garde quelque chose dans ton sac pour le creux"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "機内食のタイミングは本当に空腹になる時間と合わない——その隙間のために、バッグに何か入れておいて"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기내식 타이밍은 진짜 배고픈 시간과 맞지 않는다 — 그 공백을 위해 가방에 뭔가 챙겨두어라"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A comida do avião raramente coincide com quando você realmente está com fome — guarde algo na bolsa para o intervalo"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "航班餐的时间总跟你真正饿的时候对不上——包里备一点，备的就是那段空档"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "航班餐的時間總跟你真正餓的時候對不上——包裡備一點，備的就是那段空檔"
          }
        }
      }
    },
