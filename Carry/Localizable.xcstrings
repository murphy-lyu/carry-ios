        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tus viajes desaparecieron tras una actualización de la app o restauración del dispositivo, puedes recuperarlos desde el autoguardado más reciente a continuación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vos voyages ont disparu après une mise à jour de l'app ou une restauration de l'appareil, vous pouvez les récupérer depuis la dernière sauvegarde automatique ci-dessous."
