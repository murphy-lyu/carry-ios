    "settings.widget.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry bietet Home-Bildschirm-Widgets – deine nächste Reise und der Packfortschritt sind nur einen Blick entfernt. Halte den Home-Bildschirm gedrückt, um eines hinzuzufügen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry has Home Screen widgets, so your next trip and packing progress are just a glance away. Touch and hold the Home Screen to add one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry tiene widgets en la pantalla de inicio para ver tu próximo viaje y el progreso del equipaje de un vistazo. Mantén pulsada la pantalla de inicio para añadir uno."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry propose des widgets sur l'écran d'accueil : votre prochain voyage et l'avancement de votre valise en un coup d'œil. Appuyez longuement sur l'écran d'accueil pour en ajouter un."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry はホーム画面ウィジェットに対応。次の旅行と荷造りの進み具合がひと目でわかります。ホーム画面を長押しすると追加できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry는 홈 화면 위젯을 지원해 다음 여행과 짐 싸기 진행 상황을 한눈에 볼 수 있어요. 홈 화면을 길게 눌러 추가하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Carry tem widgets na Tela de Início para ver sua próxima viagem e o progresso da mala num relance. Toque e segure a Tela de Início para adicionar um."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry 提供桌面小部件，让你在主屏幕一眼看到即将出发的行程和打包进度。长按主屏幕空白处即可添加。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry 提供主畫面小工具，讓你在主畫面一眼看到即將出發的行程與打包進度。長按主畫面空白處即可加入。"
          }
        }
      }
    },
