    "Cruise cabin walls are magnetic — hang bags and coats with no damage" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Wände der Kreuzfahrtkabine sind magnetisch – häng Taschen und Mäntel ohne Schäden auf"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cruise cabin walls are magnetic — hang bags and coats with no damage"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las paredes del camarote del crucero son magnéticas: cuelga bolsos y abrigos sin causar daños"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les parois de la cabine de croisière sont magnétiques : suspendez sacs et manteaux sans rien abîmer"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クルーズ船のキャビンの壁は磁石が付きます。傷をつけずにバッグやコートを掛けられます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "크루즈 객실 벽은 자석이 붙어요. 손상 없이 가방과 외투를 걸 수 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As paredes da cabine do cruzeiro são magnéticas — pendure bolsas e casacos sem causar danos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "邮轮舱壁常可磁吸，挂包和外套会方便很多"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "郵輪船艙牆壁是磁性的——無損掛包包和外套"
          }
        }
      }
    },
    "Cruise cabin walls are magnetic, and most people don't know until they've already unpacked — a few hooks can completely change how the room works" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreuzfahrtkabinenwände sind magnetisch, aber die meisten wissen das erst nach dem Auspacken — ein paar Haken können die ganze Raumnutzung verändern"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las paredes de las cabinas de crucero son magnéticas, y la mayoría no lo sabe hasta que ya ha deshecho el equipaje — unos ganchos pueden cambiar completamente cómo funciona la habitación"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les murs des cabines de croisière sont magnétiques, et la plupart des gens ne le savent qu'après avoir défait leurs valises — quelques crochets peuvent complètement changer l'organisation de la pièce"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クルーズ船のキャビンの壁は磁石になっていて、多くの人は荷物を解いてから気づく——いくつかのフックが部屋の使い勝手を完全に変えてくれる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "크루즈 선실 벽은 자석이에요, 대부분의 사람들은 짐을 풀고 나서야 알게 되죠 — 후크 몇 개가 방 전체 사용 방식을 완전히 바꿔줄 수 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As paredes das cabines de cruzeiro são magnéticas, e a maioria das pessoas não sabe até já ter desfeito as malas — alguns ganchos podem mudar completamente como o quarto funciona"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "邮轮船舱墙壁是磁性的，很多人入住后才发现——几个磁钩能彻底改变房间的整洁程度"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "郵輪船艙牆壁是磁性的，很多人入住後才發現——幾個磁鉤能徹底改變房間的整潔程度"
          }
        }
      }
    },
