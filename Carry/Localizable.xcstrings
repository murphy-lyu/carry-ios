    "legal.privacy.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Carry stores everything on your device. We do not collect, transmit, or share any of your information.\n\nWe operate no servers. We use no analytics, no tracking, no advertising SDKs. We don't know who you are, where you've been, or what you've packed.\n\nWhen you enable iCloud sync (in a future version), your trips travel through Apple's CloudKit into your own iCloud account, governed by Apple's privacy policy. We have no access to that data either.\n\nLocal notifications are scheduled and delivered entirely on your device.\n\nIf you uninstall Carry, your local data goes with it. To clear iCloud data, use iOS → Settings → Apple ID → iCloud → Manage Account Storage → Carry.\n\nFor everything else, see the full version."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry stores everything on your device. We do not collect, transmit, or share any of your information.\n\nWe operate no servers. We use no analytics, no tracking, no advertising SDKs. We don't know who you are, where you've been, or what you've packed.\n\nWhen you enable iCloud sync (in a future version), your trips travel through Apple's CloudKit into your own iCloud account, governed by Apple's privacy policy. We have no access to that data either.\n\nLocal notifications are scheduled and delivered entirely on your device.\n\nWhen you use the map's location button, the app accesses your device location through Apple's MapKit framework to show your position on the map. This data stays on your device and is never sent to us.\n\nIf you uninstall Carry, your local data goes with it. To clear iCloud data, use iOS → Settings → Apple ID → iCloud → Manage Account Storage → Carry.\n\nFor everything else, see the full version."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Carry stores everything on your device. We do not collect, transmit, or share any of your information.\n\nWe operate no servers. We use no analytics, no tracking, no advertising SDKs. We don't know who you are, where you've been, or what you've packed.\n\nWhen you enable iCloud sync (in a future version), your trips travel through Apple's CloudKit into your own iCloud account, governed by Apple's privacy policy. We have no access to that data either.\n\nLocal notifications are scheduled and delivered entirely on your device.\n\nIf you uninstall Carry, your local data goes with it. To clear iCloud data, use iOS → Settings → Apple ID → iCloud → Manage Account Storage → Carry.\n\nFor everything else, see the full version."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Carry stores everything on your device. We do not collect, transmit, or share any of your information.\n\nWe operate no servers. We use no analytics, no tracking, no advertising SDKs. We don't know who you are, where you've been, or what you've packed.\n\nWhen you enable iCloud sync (in a future version), your trips travel through Apple's CloudKit into your own iCloud account, governed by Apple's privacy policy. We have no access to that data either.\n\nLocal notifications are scheduled and delivered entirely on your device.\n\nIf you uninstall Carry, your local data goes with it. To clear iCloud data, use iOS → Settings → Apple ID → iCloud → Manage Account Storage → Carry.\n\nFor everything else, see the full version."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Carry stores everything on your device. We do not collect, transmit, or share any of your information.\n\nWe operate no servers. We use no analytics, no tracking, no advertising SDKs. We don't know who you are, where you've been, or what you've packed.\n\nWhen you enable iCloud sync (in a future version), your trips travel through Apple's CloudKit into your own iCloud account, governed by Apple's privacy policy. We have no access to that data either.\n\nLocal notifications are scheduled and delivered entirely on your device.\n\nIf you uninstall Carry, your local data goes with it. To clear iCloud data, use iOS → Settings → Apple ID → iCloud → Manage Account Storage → Carry.\n\nFor everything else, see the full version."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Carry stores everything on your device. We do not collect, transmit, or share any of your information.\n\nWe operate no servers. We use no analytics, no tracking, no advertising SDKs. We don't know who you are, where you've been, or what you've packed.\n\nWhen you enable iCloud sync (in a future version), your trips travel through Apple's CloudKit into your own iCloud account, governed by Apple's privacy policy. We have no access to that data either.\n\nLocal notifications are scheduled and delivered entirely on your device.\n\nIf you uninstall Carry, your local data goes with it. To clear iCloud data, use iOS → Settings → Apple ID → iCloud → Manage Account Storage → Carry.\n\nFor everything else, see the full version."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Carry stores everything on your device. We do not collect, transmit, or share any of your information.\n\nWe operate no servers. We use no analytics, no tracking, no advertising SDKs. We don't know who you are, where you've been, or what you've packed.\n\nWhen you enable iCloud sync (in a future version), your trips travel through Apple's CloudKit into your own iCloud account, governed by Apple's privacy policy. We have no access to that data either.\n\nLocal notifications are scheduled and delivered entirely on your device.\n\nIf you uninstall Carry, your local data goes with it. To clear iCloud data, use iOS → Settings → Apple ID → iCloud → Manage Account Storage → Carry.\n\nFor everything else, see the full version."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry 将所有数据保存在你的设备上。我们不收集、不传输、也不与任何第三方共享你的信息。\n\n我们没有服务器，也没有任何数据分析、追踪、广告 SDK。我们不知道你是谁、你去过哪里、你打包了什么。\n\n当你启用 iCloud 同步（未来版本），行程会通过 Apple 的 CloudKit 进入你自己的 iCloud 账户，这部分受 Apple 隐私政策约束——我们同样无法访问。\n\n所有本地通知的调度与触发都在你的设备上完成。\n\n当你点击地图上的定位按钮时，App 会通过 Apple MapKit 框架读取你的设备位置以显示当前位置。该数据仅在设备本地处理，不会发送给我们。\n\n卸载 Carry，本地数据会一并被 iOS 删除。如需清空 iCloud 副本，前往「设置 → Apple ID → iCloud → 管理账户存储 → Carry」。\n\n本页未尽事宜以完整版为准。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry 將所有資料保存在你的裝置上。我們不收集、不傳輸、也不與任何第三方共享你的資訊。\n\n我們沒有伺服器，也沒有任何資料分析、追蹤、廣告 SDK。我們不知道你是誰、你去過哪裡、你打包了什麼。\n\n當你啟用 iCloud 同步（未來版本），行程會透過 Apple 的 CloudKit 進入你自己的 iCloud 帳戶，這部分受 Apple 隱私政策約束——我們同樣無法存取。\n\n所有本機通知的排程與觸發都在你的裝置上完成。\n\n當你點擊地圖上的定位按鈕時，App 會透過 Apple MapKit 框架讀取你的裝置位置以顯示當前位置。該資料僅在裝置本機處理，不會傳送給我們。\n\n解除安裝 Carry，本機資料會一併被 iOS 刪除。如需清空 iCloud 副本，前往「設定 → Apple ID → iCloud → 管理帳戶儲存空間 → Carry」。\n\n本頁未盡事宜以完整版為準。"
          }
        }
      }
    },
    "legal.terms.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "By using Carry, you agree to use it for personal, non-commercial purposes, on devices you own.\n\nCarry is provided \"as is\". We do our best to make it useful and reliable, but we can't guarantee it's bug-free or that every preset suggestion fits your specific trip. For critical items — passports, medication, anything you'd genuinely regret forgetting — please double-check yourself. We're not responsible for losses caused by missing items or notifications that didn't fire as expected.\n\nYour data is yours. Please back up your device regularly and don't treat Carry as the sole storage for important information.\n\nWe may change features, design, or these terms in future versions. Continued use means you accept the changes.\n\nFor anything we missed, the full version covers it."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By using Carry, you agree to use it for personal, non-commercial purposes, on devices you own.\n\nCarry is provided \"as is\". We do our best to make it useful and reliable, but we can't guarantee it's bug-free or that every preset suggestion fits your specific trip. For critical items — passports, medication, anything you'd genuinely regret forgetting — please double-check yourself. We're not responsible for losses caused by missing items or notifications that didn't fire as expected.\n\nYour data is yours. Please back up your device regularly and don't treat Carry as the sole storage for important information.\n\nWe may change features, design, or these terms in future versions. Continued use means you accept the changes.\n\nFor anything we missed, the full version covers it."
          }
        },
        "es" : {
          "stringUnit" : {
