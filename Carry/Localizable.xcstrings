    "Ten minutes of warm darkness mid-flight feels like a reset — most people who try one become converts" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zehn Minuten warme Dunkelheit auf halbem Flug fühlen sich wie ein Reset an — die meisten Menschen, die es ausprobieren, werden zu Überzeugten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ten minutes of warm darkness mid-flight feels like a reset — most people who try one become converts"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diez minutos de oscuridad cálida a mitad del vuelo se sienten como un reinicio — la mayoría de quienes lo prueban se convierten en fans"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dix minutes d'obscurité chaude en milieu de vol, c'est comme une réinitialisation — la plupart des gens qui essaient en deviennent adeptes"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フライトの中盤に10分間の温かな暗闇を過ごすとリセットした感覚になる — 一度試した人のほとんどが虜になる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "비행 중간의 따뜻한 어둠 속 10분이 리셋처럼 느껴집니다 — 한번 써본 대부분의 사람이 신봉자가 돼요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dez minutos de escuridão quente no meio do voo parecem um reset — a maioria das pessoas que experimenta se converte"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "飞行中来一段温热放松，往往能明显缓解疲惫"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "飛行中來一段溫熱放鬆，往往能明顯緩解疲憊"
          }
        }
      }
    },
