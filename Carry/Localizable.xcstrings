    "A physical book for long-haul — no battery anxiety, no glare, and you will actually finish it away from notifications" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein gedrucktes Buch für Langstrecken — kein Akku, keine Reflexionen, und ohne Benachrichtigungen liest man es wirklich zu Ende"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un libro físico para vuelos largos — sin batería, sin reflejos, y sin notificaciones realmente lo terminas"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un livre physique pour les long-courriers — sans batterie, sans reflets, et loin des notifications on le finit vraiment"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長距離フライトには紙の本を——バッテリー不要、反射なし、通知から離れてしっかり読み終えられる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "장거리 비행엔 종이책이 딱해요 — 배터리 걱정 없고, 눈부심도 없고, 알림 없이 끝까지 읽을 수 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um livro físico para voos longos — sem bateria, sem reflexo, e sem notificações você vai realmente terminar de ler"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "长途飞行，拿本实体书——不用担心没电，没有屏幕反光，远离消息才真能读完"
