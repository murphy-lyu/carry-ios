    "Regular sunscreen damages coral reefs — worth switching in tropical waters" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Herkömmliche Sonnencreme schädigt Korallenriffe – in tropischen Gewässern lohnt sich der Wechsel"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regular sunscreen damages coral reefs — worth switching in tropical waters"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El protector solar normal daña los arrecifes de coral: vale la pena cambiarlo en aguas tropicales"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La crème solaire classique abîme les récifs coralliens — mieux vaut en changer dans les eaux tropicales"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通常の日焼け止めはサンゴ礁を傷めます。熱帯の海では切り替える価値あり"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일반 자외선 차단제는 산호초를 손상시켜요. 열대 바다에서는 바꿀 만한 가치가 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O protetor solar comum danifica os corais — vale a pena trocar em águas tropicais"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
