    "Scuffed shoes undermine an otherwise sharp outfit — a quick buff before a client meeting takes thirty seconds" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zerkratzte Schuhe untergraben ein sonst schickes Outfit — ein kurzes Aufpolieren vor einem Kundengespräch dauert dreißig Sekunden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scuffed shoes undermine an otherwise sharp outfit — a quick buff before a client meeting takes thirty seconds"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los zapatos rayados arruinan un atuendo que de otro modo sería impecable — un rápido pulido antes de una reunión con un cliente lleva treinta segundos"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des chaussures éraflées gâchent une tenue par ailleurs impeccable — un rapide coup de chiffon avant une réunion client prend trente secondes"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "傷のついた靴は、それ以外は完璧なコーデを台無しにする — クライアントとの面会前に30秒サッと磨くだけでいい"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "긁힌 구두는 나머지가 완벽한 옷차림을 망칩니다 — 고객 미팅 전 30초 빠르게 닦아주는 것만으로 충분해요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sapatos riscados comprometem um visual que seria impecável — uma lustrada rápida antes de uma reunião com cliente leva trinta segundos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鞋面有划痕会影响整体状态，见面前快速处理很加分"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鞋面有劃痕會影響整體狀態，見面前快速處理很加分"
          }
        }
      }
    },
