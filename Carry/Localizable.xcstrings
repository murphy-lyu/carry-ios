    "Fill from the hotel kettle — a hot water bottle on cramps is still the most effective thing, wherever you are" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aus dem Hotelkocher füllen — eine Wärmflasche bei Krämpfen ist immer noch das Wirksamste, wo auch immer du bist"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fill from the hotel kettle — a hot water bottle on cramps is still the most effective thing, wherever you are"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Llénala con el hervidor del hotel — una bolsa de agua caliente para los cólicos sigue siendo lo más eficaz, donde sea que estés"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remplissez-la avec la bouilloire de l'hôtel — une bouillotte contre les crampes reste la chose la plus efficace, où que vous soyez"
