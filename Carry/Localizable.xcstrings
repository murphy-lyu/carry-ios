    "settings.calendar.footer" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reisen kommen in einen Kalender namens „Carry“. Erscheinen sie nicht, aktiviere „Carry“ in der Kalender-App."
          }
        },
        "en" : {
          "stringUnit" : {
