    "settings.data.import.confirm.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zusammenführen fügt neue Reisen aus dem Backup hinzu, ohne vorhandene Daten zu löschen. Ersetzen löscht zuerst alle aktuellen Daten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merge adds new trips from the backup without removing your current data. Replace removes all current data first."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Combinar añade los nuevos viajes del respaldo sin eliminar los datos actuales. Reemplazar elimina todos los datos actuales primero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fusionner ajoute les nouveaux voyages de la sauvegarde sans supprimer les données actuelles. Remplacer supprime d'abord toutes les données actuelles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「統合」はバックアップの新しい旅行を既存データを保持したまま追加します。「置き換え」は現在のデータをすべて削除してからインポートします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "병합은 현재 데이터를 유지하면서 백업의 새 여행을 추가합니다. 교체는 현재 데이터를 모두 삭제한 후 가져옵니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mesclar adiciona novas viagens do backup sem remover seus dados atuais. Substituir remove todos os dados atuais primeiro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「合并」仅导入备份中的新行程，不影响现有数据；「替换」会清除当前所有数据后重新导入。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「合併」僅匯入備份中的新行程，不影響現有資料；「取代」會清除目前所有資料後重新匯入。"
          }
        }
      }
    },
