    "During long days out, these make unfamiliar public restrooms feel much more comfortable" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei langen Tagen unterwegs machen sie unbekannte öffentliche Toiletten viel angenehmer"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durante los días largos fuera de casa, hacen que los baños públicos desconocidos se sientan mucho más cómodos"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lors de longues journées dehors, ceux-ci rendent les toilettes publiques inconnues bien plus confortables"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長い外出の日は、見知らぬ公衆トイレがずっと快適に感じられるようになる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오랜 외출 중에, 낯선 공중화장실을 훨씬 더 편하게 만들어줘요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durante longos dias de passeio, esses tornam os banheiros públicos desconhecidos muito mais confortáveis"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "长时间在外时，让陌生的公共洗手间用起来舒适很多"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長時間在外時，讓陌生的公共洗手間用起來舒適很多"
          }
        }
      }
    },
