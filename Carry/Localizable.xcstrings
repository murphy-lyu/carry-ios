    "settings.cycle.privacy" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zyklus-Tracking wird nur auf diesem Gerät gelesen – nie gespeichert oder geteilt. Jederzeit abschaltbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cycle Tracking is read on-device only — never stored or shared. Turn off anytime."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El seguimiento del ciclo se lee solo en este dispositivo, nunca se almacena ni comparte. Desactívalo cuando quieras."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le suivi du cycle est lu uniquement sur cet appareil — jamais stocké ni partagé. Désactivable à tout moment."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サイクルトラッキングはこのデバイスのみで読み取られ、保存・共有されません。いつでもオフにできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "생리 주기 기록은 이 기기에서만 읽히며 저장되거나 공유되지 않습니다. 언제든지 끌 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O rastreamento do ciclo é lido apenas neste dispositivo — nunca armazenado ou compartilhado. Desative a qualquer momento."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅在本机读取经期记录，不存储、不上传。可随时关闭。"
