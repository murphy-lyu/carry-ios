    "itinerary.import.update_note" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast diese Reise bereits. Beim Importieren wird ihr Reiseplan durch die neueste Version ersetzt – deine Packliste bleibt unverändert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You already have this trip. Importing replaces its itinerary with the latest version — your packing list stays unchanged."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya tienes este viaje. Al importarlo, su itinerario se reemplaza por la versión más reciente; tu lista de equipaje no cambia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez déjà ce voyage. L’importation remplace son itinéraire par la dernière version ; votre liste de bagages reste inchangée."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この旅程はすでにあります。インポートすると行程が最新版に置き換わります（持ち物リストはそのまま）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이미 가지고 있는 여행이에요. 가져오면 일정이 최신 버전으로 바뀌어요(짐 목록은 그대로 유지)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você já tem esta viagem. Importar substitui o itinerário pela versão mais recente; sua lista de bagagem permanece igual."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已有这个行程，导入会用最新版替换它的行程规划（打包清单不变）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已有這個行程，匯入會用最新版取代它的行程規劃（打包清單不變）。"
          }
        }
      }
    },
