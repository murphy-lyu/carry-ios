        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Répare une semelle de chaussure cassée, une sangle déchirée ou un point d'ampoule — ça vaut les 30g"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "靴底のひび、千切れたストラップ、靴擦れ箇所を修理できる — 30gの価値あり"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "부서진 신발 밑창, 찢어진 스트랩, 물집 부위를 고쳐줍니다 — 30g의 가치가 충분해요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
