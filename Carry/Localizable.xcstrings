    "Fixes a broken boot sole, a torn strap, or a blister spot — worth the 30g" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repariert eine gebrochene Schuhsohle, einen gerissenen Riemen oder eine Blasenstelle — die 30g sind es wert"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fixes a broken boot sole, a torn strap, or a blister spot — worth the 30g"
