    "settings.data.import.confirm.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle aktuellen Reisen werden durch die Daten aus der ausgewählten Datei ersetzt. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All current trips will be replaced with the data from the selected file. This cannot be undone."
