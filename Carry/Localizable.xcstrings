    "settings.notif.weather.note" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur bei extremem Wetter (Starkregen, Schnee, Hitze, offizielle Warnungen) – kein tägliches Wetter-Spam"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only fires for severe weather (heavy rain, snow, extreme heat, official alerts) — no daily forecast spam"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo para clima severo (lluvia intensa, nieve, calor extremo, alertas oficiales); sin avisos diarios"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uniquement en cas de météo extrême (fortes pluies, neige, canicule, alertes officielles), pas de spam quotidien"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "荒天（大雨・大雪・高温・公式警報など）のときだけ。毎日の通知はしない"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "악천후(폭우·폭설·폭염·공식 경보 등)에만 알려요. 매일 알리지 않아요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Só para clima severo (chuva forte, neve, calor extremo, alertas oficiais); sem spam diário"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
