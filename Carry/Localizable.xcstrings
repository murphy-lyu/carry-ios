    "Hands-free navigation is the law in most places — and your co-pilot won't always be awake" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freihändige Navigation ist an den meisten Orten gesetzlich vorgeschrieben — und dein Beifahrer wird nicht immer wach sein"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hands-free navigation is the law in most places — and your co-pilot won't always be awake"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La navegación manos libres es ley en la mayoría de los lugares — y tu copiloto no siempre estará despierto"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La navigation mains libres est obligatoire dans la plupart des endroits — et votre co-pilote ne sera pas toujours éveillé"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ハンズフリーナビはほとんどの場所で法律 — そして助手席の人が常に起きているとは限らない"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "핸즈프리 내비게이션은 대부분의 곳에서 법으로 정해져 있습니다 — 그리고 조수석의 사람이 항상 깨어 있지는 않아요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navegação viva-voz é lei na maioria dos lugares — e seu co-piloto nem sempre vai estar acordado"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "很多地方都要求免手持导航，装上支架会更安全也更省心"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大多數地方法律要求免提導航——而你的副駕駛也不會總是清醒的"
          }
        }
      }
    },
