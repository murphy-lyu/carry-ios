          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Listas de bagagem, registros de gastos e companheiros de viagem não são migrados. Locais, transporte, hospedagem, horários e custos são importados."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "打包清单、记账和同行者不会迁移。地点、交通、住宿、时间和费用会一并导入。"
