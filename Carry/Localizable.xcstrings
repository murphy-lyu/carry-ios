    "about.tagline" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry was built around a simple idea: never again think \"did I forget something?\" right before you head out the door. We hope it helps you pack a little more calmly, so you can spend that headspace on the trip itself."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry 源于一个简单的想法：出门前不再为「这次会不会忘了带什么」而焦虑。希望它能帮你整理得更从容一些，把那份心力留给旅程本身。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry 源於一個簡單的想法：出門前不再為「這次會不會忘了帶什麼」而焦慮。希望它能幫你整理得更從容一些,把那份心力留給旅程本身。"
          }
        }
      }
    },
