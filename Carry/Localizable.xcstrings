    "phototrip.excluded.nolocation.hint" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Fotos haben kein GPS in der Datei (z. B. Screenshots, gespeicherte Bilder oder die Ortung war aus) und können nicht verortet werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These photos have no GPS in their file (e.g. screenshots, saved or downloaded images, or location was off when taken), so they can't be placed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas fotos no tienen GPS en su archivo (p. ej. capturas, imágenes guardadas, o la ubicación estaba desactivada), así que no se pueden ubicar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ces photos n'ont pas de GPS dans leur fichier (captures d'écran, images enregistrées, ou localisation désactivée) et ne peuvent pas être placées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらの写真はファイルに GPS がない（スクリーンショットや保存画像、撮影時に位置情報がオフなど）ため、場所を特定できない。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 사진들은 파일에 GPS가 없어요(스크린샷·저장된 이미지거나 촬영 시 위치가 꺼져 있었어요). 그래서 위치를 정할 수 없어요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas fotos não têm GPS no arquivo (capturas de tela, imagens salvas ou localização desligada), então não podem ser posicionadas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这些照片的文件里没有 GPS（如截图、转存的图，或拍摄时关了定位），所以无法定位。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這些照片的檔案裡沒有 GPS（如截圖、轉存的圖，或拍攝時關了定位），所以無法定位。"
          }
        }
      }
    },
