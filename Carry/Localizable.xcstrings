    "Driving in heels reduces pedal feel and reaction time — a pair of flats to swap into before getting behind the wheel makes a real difference on long stretches" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fahren in High Heels vermindert das Pedalgefühl und die Reaktionszeit — ein Paar flache Schuhe zum Wechseln vor dem Steuer macht auf langen Strecken wirklich einen Unterschied"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Driving in heels reduces pedal feel and reaction time — a pair of flats to swap into before getting behind the wheel makes a real difference on long stretches"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conducir con tacones reduce la sensación del pedal y el tiempo de reacción — un par de zapatos planos para ponerse antes de ponerse al volante marca una diferencia real en trayectos largos"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conduire en talons réduit le ressenti de la pédale et le temps de réaction — une paire de chaussures plates à enfiler avant de prendre le volant fait vraiment la différence sur de longs trajets"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ヒールで運転するとペダルの感覚と反応時間が落ちる — 運転前にフラットシューズに履き替えると、長距離では大きな差が出る"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "힐을 신고 운전하면 페달 감각과 반응 속도가 떨어집니다 — 운전 전에 갈아 신을 플랫 슈즈 한 켤레가 장거리에서 큰 차이를 만들어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dirigir de salto reduz a sensação no pedal e o tempo de reação — um par de sapatilhas para calçar antes de pegar a direção faz diferença real em longos percursos"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "穿高跟鞋开车会影响脚感和反应，准备一双平底鞋，长途驾驶会轻松很多"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "穿高跟鞋開車會影響腳感和反應，準備一雙平底鞋，長途駕駛會輕鬆很多"
          }
        }
      }
    },
