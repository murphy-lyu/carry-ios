    "Temperatures drop fast after sunset at altitude even in summer — always have one layer extra" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Temperatures drop fast after sunset at altitude even in summer — always have one layer extra"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在高海拔，即使夏天日落后温度也会迅速下降——永远多备一层"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在高海拔，即使夏天日落後溫度也會迅速下降——永遠多備一層"
          }
        }
      }
    },
    "The face and neck lose heat fastest — often warmer than an extra torso layer" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The face and neck lose heat fastest — often warmer than an extra torso layer"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "面部和颈部散热最快——通常比多穿一件躯干衣物更暖"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "面部和頸部散熱最快——通常比多穿一件軀幹衣物更暖"
          }
        }
      }
    },
    "The layer closest to your skin matters most — cheap thermals from a supermarket are better than nothing" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The layer closest to your skin matters most — cheap thermals from a supermarket are better than nothing"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最贴近皮肤的那层最重要——超市买的廉价保暖内衣也胜于无"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最貼近皮膚的那層最重要——超市買的廉價保暖內衣也勝於無"
          }
        }
      }
    },
    "The prescription medication for altitude sickness prevention — ask your GP at least a week before you go" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The prescription medication for altitude sickness prevention — ask your GP at least a week before you go"
