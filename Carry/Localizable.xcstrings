    "notif.1week.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie läuft die Planung? Orte und Unterkünfte schon im Blick?"
