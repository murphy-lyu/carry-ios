    "settings.developer.clear_calendar_ids.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Löscht die Aufzeichnung, welche Reisen bereits zum Kalender hinzugefügt wurden, um den Ablauf erneut zu testen. Bestehende Kalendereinträge bleiben erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clears the record of which trips were already added to Calendar, so the add-to-calendar flow can be tested again. Does not delete existing calendar events."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borra el registro de qué viajes ya se añadieron al calendario para volver a probar el flujo. No elimina los eventos existentes del calendario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Efface l'enregistrement des voyages déjà ajoutés au calendrier afin de retester le flux. Ne supprime pas les événements existants du calendrier."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どの旅行が既にカレンダーに追加されたかの記録を消去し、追加フローを再テストできるようにします。既存のカレンダーイベントは削除されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어떤 여행이 이미 캘린더에 추가되었는지에 대한 기록을 지워 추가 흐름을 다시 테스트할 수 있게 합니다. 기존 캘린더 이벤트는 삭제하지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpa o registro de quais viagens já foram adicionadas ao calendário para testar o fluxo novamente. Não exclui eventos existentes do calendário."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除「哪些行程已加入日历」的记录，以便重新测试加入日历流程。不会删除日历中已存在的事件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除「哪些行程已加入日曆」的記錄，以便重新測試加入日曆流程。不會刪除日曆中已存在的事件。"
          }
        }
      }
    },
