    "Mess-free drawing that resets instantly — endlessly reusable on long journeys" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ordentliches Zeichnen, das sich sofort zurücksetzt — endlos wiederverwendbar auf langen Reisen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
