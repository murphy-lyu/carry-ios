    "Chewing one before landing helps with dry cabin mouth and makes you feel fresher on arrival" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eines vor der Landung kauen hilft gegen Mundtrockenheit in der Kabine und lässt einen frischer ankommen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masticar uno antes de aterrizar alivia la sequedad bucal en cabina y te hace sentir más fresco al llegar"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En mâcher un avant l'atterrissage aide contre la bouche sèche en cabine et vous fait sentir plus frais à l'arrivée"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "着陸前に一粒噛むと機内の口の乾燥が和らぎ、到着時にすっきりした気分になれる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "착륙 전에 하나 씹으면 건조한 기내 구강을 해소하고 도착 시 더 상쾌해져요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mastigar um antes de pousar ajuda com a boca seca na cabine e faz você se sentir mais disposto na chegada"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "落地前嚼一片，缓解机舱口干，到达时更精神"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "落地前嚼一片，緩解機艙口乾，到達時更精神"
          }
        }
      }
    },
