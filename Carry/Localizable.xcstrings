    "phototrip.intro.privacy" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Fotos bleiben auf deinem Gerät. Carry liest nur Zeit und Ort jedes Fotos – lädt sie nie hoch und speichert nur ein kleines Vorschaubild im Reiseverlauf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your photos stay on your device. Carry only reads each photo's time and place — it never uploads them, and saves just a small thumbnail to your itinerary."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tus fotos permanecen en tu dispositivo. Carry solo lee la hora y el lugar de cada foto; nunca las sube y solo guarda una miniatura en tu itinerario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos photos restent sur votre appareil. Carry lit seulement l'heure et le lieu de chaque photo ; il ne les téléverse jamais et n'enregistre qu'une petite miniature dans votre itinéraire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真は端末内にとどまる。Carry は各写真の時刻と場所だけを読み取り、アップロードは一切せず、旅程には小さなサムネイルだけを保存する。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진은 기기에만 남아요. Carry는 각 사진의 시간과 장소만 읽고, 절대 업로드하지 않으며, 일정에는 작은 썸네일만 저장해요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suas fotos permanecem no seu dispositivo. O Carry só lê a hora e o local de cada foto — nunca as envia e salva apenas uma miniatura no seu roteiro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "照片只留在你的设备上。Carry 只读取每张照片的时间和地点，绝不上传，只在行程里存一张小缩略图。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "照片只留在你的裝置上。Carry 只讀取每張照片的時間與地點，絕不上傳，只在行程裡存一張小縮圖。"
          }
        }
      }
    },
    "phototrip.intro.subtitle" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle Fotos dieser Reise aus – Carry liest Zeit und Ort aus, um die besuchten Orte zu rekonstruieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pick photos from this trip and Carry reads their time and location to rebuild the places you visited."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige fotos de este viaje y Carry leerá su hora y ubicación para reconstruir los lugares que visitaste."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez des photos de ce voyage : Carry lit leur heure et leur lieu pour reconstituer les endroits visités."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この旅行の写真を選ぶと、Carry が時刻と位置情報を読み取り、訪れた場所を再現する。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 여행의 사진을 고르면 Carry가 사진의 시간과 위치를 읽어 다녀온 장소를 되살려요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha fotos desta viagem e o Carry lê a hora e o local delas para reconstruir os lugares que você visitou."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择这趟旅行的照片，Carry 读取它们的时间和位置，自动还原你去过的地点。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選擇這趟旅行的照片，Carry 會讀取它們的時間與位置，自動還原你去過的地點。"
          }
        }
      }
    },
