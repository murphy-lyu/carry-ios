    "Eight hours at a screen in a new place. A small defence against the slow headache that builds through the afternoon" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acht Stunden am Bildschirm an einem neuen Ort. Ein kleiner Schutz gegen den Kopfschmerz, der sich nachmittags aufbaut"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eight hours at a screen in a new place. A small defence against the slow headache that builds through the afternoon"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ocho horas frente a una pantalla en un lugar nuevo. Una pequeña defensa contra el dolor de cabeza que se acumula por la tarde"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Huit heures devant un écran dans un nouvel endroit. Une petite protection contre le mal de tête qui s'installe dans l'après-midi"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しい場所でスクリーンの前に8時間。午後になるにつれてじわじわと積み重なる頭痛への、小さな防御"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "낯선 곳에서 화면 앞에서 8시간. 오후가 될수록 서서히 쌓이는 두통에 대한 작은 방어"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oito horas em uma tela num lugar novo. Uma pequena defesa contra a dor de cabeça que se acumula ao longo da tarde"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在陌生的地方盯着屏幕八个小时。这个小小的防护，能让你少一点下午慢慢积累的头疼"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在陌生的地方盯著螢幕八個小時。這個小小的防護，能讓你少一點下午慢慢積累的頭疼"
          }
        }
      }
    },
