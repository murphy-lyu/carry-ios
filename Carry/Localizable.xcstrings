    "Waterproofing documents, organising small items, separating wet clothes — endlessly useful" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dokumente wasserdicht machen, kleine Gegenstände ordnen, nasse Kleidung trennen — endlos nützlich"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Waterproofing documents, organising small items, separating wet clothes — endlessly useful"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impermeabilizar documentos, organizar artículos pequeños, separar ropa mojada — infinitamente útil"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protéger les documents de l'eau, organiser les petits objets, séparer les vêtements mouillés — infiniment utile"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "書類の防水、小物の整理、濡れた衣類の分離 — 使い道は無限"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "서류 방수 처리, 소지품 정리, 젖은 옷 분리 — 끝없이 유용합니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impermeabilizar documentos, organizar itens pequenos, separar roupas molhadas — infinitamente útil"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "防水收纳证件、分类小物、隔离湿衣服都很实用"
