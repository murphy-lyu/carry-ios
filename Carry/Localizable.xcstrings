    "autopick.review.subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir haben Artikel basierend auf deinen Szenarien vorausgewählt. Entferne was du nicht brauchst oder füge mehr hinzu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We've pre-selected items based on your scenes. Remove what you don't need or add more."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hemos preseleccionado artículos según tus escenas. Elimina lo que no necesites o añade más."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous avons présélectionné des articles selon vos scènes. Supprimez ce dont vous n'avez pas besoin ou ajoutez-en d'autres."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "シーンに基づいてアイテムを事前選択しました。不要なものを削除するか、追加してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여행 장면을 기반으로 물품을 미리 선택했습니다. 필요 없는 것은 제거하거나 더 추가하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selecionamos itens com base nos seus cenários. Remova o que não precisa ou adicione mais."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已根据你的出行场景预选了物品，取消不需要的，或继续补充。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已根據你的出行場景預選了物品，取消不需要的，或繼續補充。"
          }
        }
      }
    },
