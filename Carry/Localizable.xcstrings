      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Packlisten, Ausgaben und Mitreisende werden nicht übernommen. Orte, Transport, Unterkünfte, Zeiten und Kosten werden übertragen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Packing lists, expense logs, and travel companions aren’t migrated. Places, transport, lodging, times, and costs come over."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las listas de equipaje, los gastos y los acompañantes no se migran. Sí se importan lugares, transporte, alojamiento, horarios y costos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les listes de bagages, les dépenses et les compagnons de voyage ne sont pas migrés. Les lieux, transports, hébergements, horaires et coûts sont importés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パッキングリスト・支出記録・同行者は移行されない。場所・移動・宿泊・時刻・費用は取り込まれる。"
