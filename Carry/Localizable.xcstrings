    "Public restrooms and small shops do not always have tissues — this tiny backup saves the moment more often than you think" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffentliche Toiletten und kleine Läden haben nicht immer Taschentücher — dieses kleine Backup hilft öfter als man denkt"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los baños públicos y las tiendas pequeñas no siempre tienen pañuelos — este pequeño recurso salva el momento más a menudo de lo que crees"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les toilettes publiques et les petits commerces n'ont pas toujours de mouchoirs — ce petit filet de sécurité rend service plus souvent qu'on ne le croit"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公衆トイレや小さな店には常にティッシュがあるとは限らない——この小さな予備は、思う以上によく役に立つ"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "공중화장실과 작은 가게에는 항상 화장지가 있지 않아요 — 이 작은 비상용이 생각보다 훨씬 자주 필요해요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Banheiros públicos e pequenas lojas nem sempre têm lenços — esse pequeno backup salva o momento com mais frequência do que você imagina"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公厕和小店不一定有纸巾——这个小备品出手的次数，比你以为的多"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公廁和小店不一定有紙巾——這個小備品出手的次數，比你以為的多"
          }
        }
      }
    },
    "Pull on over any shoes in seconds — keeps feet dry without having to plan your footwear around the forecast" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In Sekunden über jedes Schuhwerk ziehen — Füße trocken halten, ohne das Schuhwerk nach der Wettervorhersage planen zu müssen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pull on over any shoes in seconds — keeps feet dry without having to plan your footwear around the forecast"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ponlos sobre cualquier zapato en segundos — mantiene los pies secos sin tener que planificar el calzado según la previsión meteorológica"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "À enfiler par-dessus n'importe quelle chaussure en secondes — garde les pieds secs sans avoir à planifier sa chaussure selon la météo"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どんな靴の上にも数秒で装着 — 天気予報に合わせて靴を選ばなくても足を乾いた状態に保てる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어떤 신발 위에도 몇 초 만에 착용 — 날씨 예보에 맞춰 신발을 계획하지 않아도 발을 건조하게 유지해줘요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coloque por cima de qualquer sapato em segundos — mantém os pés secos sem precisar planejar o calçado conforme a previsão"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "套上就能防雨，不用为天气专门换鞋"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "套上就能防雨，不用為天氣專門換鞋"
          }
        }
      }
    },
