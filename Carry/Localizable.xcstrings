    "Shoes off, slippers on — a small ritual that makes a long flight feel far more civilised" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schuhe aus, Hausschuhe an — ein kleines Ritual, das einen langen Flug weit zivilisierter erscheinen lässt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shoes off, slippers on — a small ritual that makes a long flight feel far more civilised"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zapatos fuera, zapatillas puestas — un pequeño ritual que hace que un vuelo largo se sienta mucho más civilizado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaussures enlevées, chaussons enfilés — un petit rituel qui rend un long vol beaucoup plus civilisé"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "靴を脱いでスリッパに履き替える — 長いフライトをずっと快適にする小さな儀式"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신발 벗고, 슬리퍼 신고 — 긴 비행을 훨씬 편안하게 만들어 주는 작은 의식"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sapatos fora, chinelos calçados — um pequeno ritual que torna um voo longo muito mais civilizado"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "长途飞行换上拖鞋，体感会更放松"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長途飛行換上拖鞋，體感會更放鬆"
          }
        }
      }
    },
