    "When coffee or sauce lands on light clothes, a quick swipe can save you from a whole day of awkward stains" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Kaffee oder Sauce auf helle Kleidung fällt, kann ein schneller Wisch einen ganzen Tag peinlicher Flecken ersparen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando el café o la salsa cae sobre ropa clara, un rápido pase puede ahorrarte un día entero de manchas incómodas"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quand le café ou la sauce tombe sur des vêtements clairs, un coup rapide peut vous éviter une journée entière de taches gênantes"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "淡い服にコーヒーやソースが垂れたとき、さっとひと拭きで一日中恥ずかしいシミを防げる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "커피나 소스가 밝은 색 옷에 묻었을 때, 빠르게 한 번 닦으면 하루 종일 어색한 얼룩에서 벗어날 수 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando café ou molho cai em roupas claras, uma rápida passada pode te salvar de um dia inteiro com manchas constrangedoras"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "咖啡或酱料滴到浅色衣服时，快速擦一下，能避免一整天的尴尬"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "咖啡或醬料滴到淺色衣服時，快速擦一下，能避免一整天的尷尬"
          }
        }
      }
    },
    "Window sunshade" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
