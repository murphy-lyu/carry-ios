    "Compact enough to slip in a day bag — a quick few breaths at altitude does genuinely help, and the peace of mind is worth it" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klein genug für eine Tagestasche — ein paar Atemzüge auf großer Höhe helfen wirklich, und die Sicherheit ist es wert"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compact enough to slip in a day bag — a quick few breaths at altitude does genuinely help, and the peace of mind is worth it"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo suficientemente compacto para meterlo en una bolsa de día — unos rápidos sorbos de oxígeno en altura ayudan de verdad, y la tranquilidad vale la pena"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assez compact pour glisser dans un sac de jour — quelques respirations rapides en altitude aident vraiment, et la tranquillité d'esprit vaut le coup"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デイバッグに入るほどコンパクト — 高地でさっと数回吸うだけで確かに効果があり、安心感も格別"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "데이백에 쏙 들어갈 만큼 컴팩트합니다 — 고지대에서 몇 번 들이마시면 진짜 도움이 되고, 안심감도 충분히 값어치 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compacto o suficiente para caber numa bolsa de dia — algumas respiradas em altitude realmente ajudam, e a tranquilidade vale a pena"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "体积小，放随身包里，高海拔时会更安心"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "體積小，放隨身包裡，高海拔時會更安心"
          }
        }
      }
    },
