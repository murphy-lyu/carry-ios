    "Skin that's had a good day in the sun deserves this in the evening — the difference between waking up glowing and waking up sore" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haut, die einen schönen Tag in der Sonne hatte, verdient das abends — der Unterschied zwischen strahlend und schmerzhaft aufwachen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skin that's had a good day in the sun deserves this in the evening — the difference between waking up glowing and waking up sore"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La piel que ha tenido un buen día al sol merece esto por la noche — la diferencia entre despertar radiante y despertar adolorida"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La peau qui a passé une belle journée au soleil mérite ça le soir — la différence entre se réveiller lumineuse et se réveiller douloureuse"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "日光を浴びた肌は夜にこれを使う価値があります。輝いて目覚めるか、痛みで目覚めるかの違いはここにあります"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "햇볕 아래서 좋은 하루를 보낸 피부는 저녁에 이것을 받을 자격이 있습니다. 빛나게 일어나는 것과 따갑게 일어나는 것의 차이입니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A pele que passou um bom dia ao sol merece isso à noite — a diferença entre acordar radiante e acordar dolorida"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在阳光下度过美好一天的皮肤，值得在晚上被这样对待——醒来焕发光彩和醒来红痛刺痛，就差这一步"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在陽光下度過美好一天的皮膚，值得在晚上被這樣對待——醒來煥發光彩和醒來紅痛刺痛，就差這一步"
          }
        }
      }
    },
    "Skirt" : {
