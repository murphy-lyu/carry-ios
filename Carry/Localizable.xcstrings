    "tripsy_import.note.merge" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Importierte Reisen werden zu deinen bestehenden hinzugefügt – nichts wird überschrieben. Beim erneuten Import desselben Backups werden bereits hinzugefügte Reisen übersprungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imported trips are added to your existing ones — nothing is overwritten. Importing the same backup again skips trips already added."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los viajes importados se añaden a los que ya tienes; no se sobrescribe nada. Si importas la misma copia otra vez, se omiten los viajes ya añadidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les voyages importés s’ajoutent à vos voyages existants : rien n’est écrasé. Réimporter la même sauvegarde ignore les voyages déjà ajoutés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "読み込んだ旅行は既存の旅行に追加され、上書きはされない。同じバックアップを再度読み込むと、追加済みの旅行はスキップされる。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가져온 여행은 기존 여행에 추가되며 아무것도 덮어쓰지 않아요. 같은 백업을 다시 가져오면 이미 추가된 여행은 건너뛰어요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As viagens importadas são adicionadas às existentes — nada é sobrescrito. Importar o mesmo backup de novo ignora viagens já adicionadas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "导入的行程会新增到你现有行程中，不会覆盖任何数据。重复导入同一备份会自动跳过已导入的行程。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "匯入的行程會新增到你現有行程中，不會覆蓋任何資料。重複匯入同一備份會自動略過已匯入的行程。"
          }
        }
      }
    },
