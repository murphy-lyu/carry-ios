    "Small, travel-friendly, and creates its own atmosphere — worth the space" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klein, reisefreundlich und schafft eine eigene Atmosphäre — den Platz wert"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Small, travel-friendly, and creates its own atmosphere — worth the space"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pequeña, ideal para viajar y crea su propia atmósfera — vale el espacio"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Petite, adaptée au voyage et crée sa propre atmosphère — ça vaut l'espace"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小さくて旅行向き、そして独自の雰囲気を生み出す — スペースを取る価値がある"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "작고 여행 친화적이며 자신만의 분위기를 만들어 줍니다 — 공간을 차지할 가치가 있어요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pequena, ideal para viagem e cria sua própria atmosfera — vale o espaço"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "体积小、便于携带，也能快速营造放松氛围"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "小巧、旅行友好，自帶氛圍——值得占用那點空間"
          }
        }
      }
    },
