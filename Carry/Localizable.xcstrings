    "Warm hands change everything in the cold — and unlike disposable ones, this one charges your phone in a pinch too" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warme Hände verändern alles in der Kälte — und im Gegensatz zu Einwegwärmern lädt dieser im Notfall auch dein Handy auf"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warm hands change everything in the cold — and unlike disposable ones, this one charges your phone in a pinch too"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las manos cálidas lo cambian todo en el frío — y a diferencia de los desechables, este también carga tu teléfono en un apuro"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Des mains chaudes changent tout dans le froid — et contrairement aux modèles jetables, celui-ci peut aussi recharger votre téléphone en cas de besoin"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "冷たい中で温かい手はすべてを変えます。使い捨てと違い、緊急時にはスマホの充電もできます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "추운 날씨에 따뜻한 손은 모든 것을 바꿉니다. 일회용과 달리 급할 때 폰도 충전할 수 있습니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mãos quentes mudam tudo no frio — e ao contrário dos descartáveis, este também carrega seu celular em uma emergência"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暖手在寒冷中改变一切——而且它不只是暖手宝，紧急时还能给手机充电"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暖手在寒冷中改變一切——而且它不只是暖手寶，緊急時還能給手機充電"
          }
        }
      }
    },
