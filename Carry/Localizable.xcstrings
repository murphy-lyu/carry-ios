    "notif.1day.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heute Abend packen — du wirst dir morgen früh dankbar sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pack tonight — you'll thank yourself in the morning."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz las maletas esta noche — te lo agradecerás por la mañana."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites vos valises ce soir — vous vous en féliciterez demain matin."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今夜荷造りを — 明日の朝に感謝するはず。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오늘 밤 짐을 싸세요 — 내일 아침 고마워할 거예요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faça as malas esta noite — você vai se agradecer amanhã de manhã."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今晚把行李收拾好，明天出门一身轻～"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今晚把行李收拾好，明天出門一身輕～"
          }
        }
      }
    },
