        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los viajes van a un calendario llamado «Carry». Si no aparecen, activa «Carry» en la app Calendario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les voyages vont dans un calendrier nommé « Carry ». S’ils n’apparaissent pas, activez « Carry » dans l’app Calendrier."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "旅行は「Carry」カレンダーに追加されます。表示されない場合は、カレンダーAppで「Carry」をオンにしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여행은 \"Carry\" 캘린더에 추가돼요. 표시되지 않으면 캘린더 앱에서 \"Carry\"를 켜 주세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As viagens vão para um calendário chamado \"Carry\". Se não aparecerem, ative \"Carry\" no app Calendário."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "行程会加入名为「Carry」的日历。若未显示，请在「日历」App 中勾选「Carry」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "行程會加入名為「Carry」的日曆。若未顯示，請在「日曆」App 中勾選「Carry」。"
          }
        }
      }
    },
    "settings.calendar.overlay.footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur lesen – wähle, welche Kalender angezeigt werden. Diese Ereignisse bleiben auf deinem Gerät und erscheinen nie in geteilten oder exportierten Reisen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Read-only — pick which calendars to show. These events stay on your device and never appear in shared or exported trips."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo lectura: elige qué calendarios mostrar. Estos eventos permanecen en tu dispositivo y nunca aparecen en viajes compartidos o exportados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lecture seule — choisissez les calendriers à afficher. Ces événements restent sur votre appareil et n’apparaissent jamais dans les voyages partagés ou exportés."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "読み取り専用——表示するカレンダーを選べます。これらの予定はデバイスに留まり、共有・書き出した旅程には表示されません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "읽기 전용 — 표시할 캘린더를 선택하세요. 이 이벤트는 기기에만 남으며 공유하거나 내보낸 여행에는 나타나지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Somente leitura — escolha quais calendários mostrar. Esses eventos ficam no seu dispositivo e nunca aparecem em viagens compartilhadas ou exportadas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只读——选择显示哪些日历。这些事件只留在你的设备上，不会出现在分享或导出的行程里。"
