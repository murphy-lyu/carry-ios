    "Volume-limited and properly sized — lets them watch their shows without disturbing everyone around them" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lautstärkebegrenzt und richtig dimensioniert — lässt sie ihre Sendungen schauen, ohne alle um sie herum zu stören"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volume-limited and properly sized — lets them watch their shows without disturbing everyone around them"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con volumen limitado y tamaño adecuado — les permite ver sus programas sin molestar a todos los que les rodean"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volume limité et taille adaptée — leur permet de regarder leurs émissions sans déranger tout le monde autour"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音量制限付きで適切なサイズ — 周りの人を邪魔せずに番組を楽しめる"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "볼륨 제한이 있고 적절한 크기 — 주변 사람들을 방해하지 않고 자신의 프로그램을 볼 수 있게 해줍니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Com volume limitado e tamanho adequado — deixa eles assistirem seus programas sem incomodar ninguém ao redor"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音量限制更安心，也能让孩子安静看内容不打扰别人"
