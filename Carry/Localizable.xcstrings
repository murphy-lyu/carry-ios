    "Real hunger hits on a long ascent — something dense and rewarding at the summit makes the whole climb feel worth it" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Echter Hunger trifft beim langen Aufstieg — etwas Nahrhaftes und Belohnendes am Gipfel lässt den gesamten Aufstieg lohnenswert erscheinen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Real hunger hits on a long ascent — something dense and rewarding at the summit makes the whole climb feel worth it"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El hambre de verdad golpea en un largo ascenso — algo denso y reconfortante en la cima hace que toda la subida valga la pena"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La vraie faim frappe lors d'une longue montée — quelque chose de consistant et de satisfaisant au sommet donne l'impression que toute la montée en valait la peine"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長い登りで本物の空腹感が押し寄せる — 山頂での満足感のある食べ物が、登り全体を報われる体験にする"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "긴 오르막에서 진짜 배고픔이 찾아옵니다 — 정상에서 묵직하고 보람 있는 것을 먹으면 전체 등반이 가치 있게 느껴져요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A fome de verdade bate numa longa subida — algo denso e recompensador no cume faz toda a escalada valer a pena"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "长上坡时很容易突然饿，一点高能量补给会很关键"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "長上坡時很容易突然餓，一點高能量補給會很關鍵"
          }
        }
      }
    },
