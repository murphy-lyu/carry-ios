    "Fixes a broken boot sole, a torn strap, or a blister spot — worth the 30g" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repariert eine gebrochene Schuhsohle, einen gerissenen Riemen oder eine Blasenstelle — die 30g sind es wert"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fixes a broken boot sole, a torn strap, or a blister spot — worth the 30g"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Repara una suela rota, una correa desgarrada o un punto de ampolla — vale los 30g"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Répare une semelle de chaussure cassée, une sangle déchirée ou un point d'ampoule — ça vaut les 30g"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "靴底のひび、千切れたストラップ、靴擦れ箇所を修理できる — 30gの価値あり"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "부서진 신발 밑창, 찢어진 스트랩, 물집 부위를 고쳐줍니다 — 30g의 가치가 충분해요"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conserta solado quebrado, alça rasgada ou bolha — vale os 30g"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鞋底开胶、背带开裂或防磨都能应急，重量却很轻"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "修復斷裂的靴底、撕裂的背帶或水泡部位——30克值了"
          }
        }
      }
    },
