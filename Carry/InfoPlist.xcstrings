    "CFBundleName" : {
      "comment" : "Bundle name",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry"
          }
        }
      }
    },
    "Carry Trip" : {},
    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Full Access Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry fügt deine Reisen und Pack-Erinnerungen zu deinem Kalender hinzu und kann deine vorhandenen Termine neben deinem Reiseplan anzeigen. Diese Daten bleiben auf deinem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry adds your trips and packing reminders to your calendar, and can show your existing events alongside your itinerary. This data stays on your device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry añade tus viajes y recordatorios de equipaje a tu calendario y puede mostrar tus eventos existentes junto a tu itinerario. Estos datos permanecen en tu dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry ajoute vos voyages et rappels de bagages à votre calendrier et peut afficher vos événements existants à côté de votre itinéraire. Ces données restent sur votre appareil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "旅行と荷造りのリマインダーをカレンダーに追加し、既存の予定を旅程の横に表示することもできます。これらのデータは端末内に保持されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여행과 짐 싸기 알림을 캘린더에 추가하고, 기존 일정을 여정 옆에 함께 표시할 수 있습니다. 이 데이터는 기기에 남습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Carry adiciona suas viagens e lembretes de bagagem ao seu calendário e pode mostrar seus eventos existentes ao lado do seu itinerário. Esses dados permanecem no seu dispositivo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启程把你的行程和打包提醒写入日历，并可将你已有的日历事件叠加显示在行程旁。相关数据仅保留在你的设备上。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟程把你的行程和打包提醒寫入行事曆，並可將你既有的行事曆活動疊加顯示在行程旁。相關資料僅保留在你的裝置上。"
          }
        }
      }
    },
    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry nutzt die Kamera, damit du Dokumente – etwa einen Mietvertrag oder eine Hotelbestätigung – fotografieren und deiner Reise anhängen kannst. Die Fotos bleiben nur auf deinem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry uses the camera so you can photograph documents — like a rental contract or hotel confirmation — and attach them to your trip. Photos are stored only on your device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry usa la cámara para que puedas fotografiar documentos —como un contrato de alquiler o una confirmación de hotel— y adjuntarlos a tu viaje. Las fotos se guardan solo en tu dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry utilise l’appareil photo pour que vous puissiez photographier des documents — comme un contrat de location ou une confirmation d’hôtel — et les joindre à votre voyage. Les photos restent uniquement sur votre appareil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "レンタル契約書やホテルの予約確認書などの書類を撮影して旅行に添付できるよう、カメラを使用します。写真は端末内にのみ保存されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "렌터카 계약서나 호텔 예약 확인서 같은 서류를 촬영해 여행에 첨부할 수 있도록 카메라를 사용합니다. 사진은 기기에만 저장됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Carry usa a câmera para você fotografar documentos — como um contrato de aluguel ou uma confirmação de hotel — e anexá-los à sua viagem. As fotos ficam apenas no seu dispositivo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启程使用相机，让你拍摄合同、确认函等文件并附加到行程。照片仅保存在你的设备本机。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟程使用相機，讓你拍攝合約、確認函等文件並附加到行程。相片僅儲存在你的裝置本機。"
          }
        }
      }
    },
    "NSHealthShareUsageDescription" : {
      "comment" : "Privacy - Health Share Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry liest deine Zyklusdaten auf dem Gerät, um dich ans Einpacken von Periodenartikeln zu erinnern, wenn eine Reise in deine Periode fallen könnte. Diese Daten verlassen dein Gerät nie."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry reads your Cycle Tracking on-device to remind you to pack period essentials when a trip may overlap your period. This data never leaves your device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry lee tu seguimiento del ciclo en el dispositivo para recordarte llevar productos para la menstruación cuando un viaje pueda coincidir con tu periodo. Estos datos nunca salen de tu dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry lit votre suivi de cycle sur l'appareil pour vous rappeler d'emporter des produits menstruels lorsqu'un voyage pourrait coïncider avec vos règles. Ces données ne quittent jamais votre appareil."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "旅行が生理と重なりそうなときに生理用品の持ち物をお知らせするため、デバイス上で周期記録を読み取る。このデータが端末の外に出ることはない。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여행이 생리 기간과 겹칠 수 있을 때 생리용품 챙기기를 알려드리기 위해 기기에서 생리 주기 기록을 읽습니다. 이 데이터는 기기를 벗어나지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Carry lê seu acompanhamento de ciclo no dispositivo para lembrá-lo de levar itens de menstruação quando uma viagem puder coincidir com seu período. Esses dados nunca saem do seu dispositivo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启程在本机读取你的经期记录，以便在行程可能赶上经期时提醒你携带相关物品。这些数据仅保留在你的设备上，绝不会上传。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟程在本機讀取你的生理期記錄，以便在行程可能遇上生理期時提醒你攜帶相關物品。這些資料僅保留在你的裝置上，絕不會上傳。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry verwendet Ihren Standort, um Ihre aktuelle Position auf der Reisekarte anzuzeigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry uses your location to show your current position on the travel map."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry usa tu ubicación para mostrar tu posición actual en el mapa de viaje."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carry utilise votre position pour l'afficher sur la carte de voyage."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在地をマップに表示するために位置情報を使用します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여행 지도에서 현재 위치를 표시하기 위해 위치를 사용합니다。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Carry usa sua localização para exibir sua posição atual no mapa de viagem."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启程使用你的位置在旅行地图上显示你的当前位置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "啟程使用你的位置在旅行地圖上顯示你目前的位置。"
          }
        }
      }
    }
  },
  "version" : "1.0"
}
